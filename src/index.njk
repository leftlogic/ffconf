---
id: home
layout: layouts/base
css: home.css
---

<section>
  <header class="vevent">
    <h2 class="summary">FFConf is a room full of people who still give a damn about the web and it's community.</h2>
    <div class="next-event">
      <a href="{{ next.url }}" class="block" target="_blank">
        <p class="next-icon">Latest event</p>
        <h3><abbr class="url dtstart" title="{{ next.date }}">{{ next.date | format }}</abbr></h3>
      </a>
      <a href="{{ tickets.url }}" class="block ticket-icon" target="_blank">
        Tickets
      </a>
    </div>
    <a href="{{ collections.posts.url }}" class="next">
      <p class="post-icon">Latest blog post</p>
      <h3 class="url">{{ collections.posts.data.title }}</h3>
    </a>
  </header>

  <div class="talk-text-cards">
  {% set talk = collections.randomLatest[0] %}
  {% include "talk-text-card.njk" %}
  {% set talk = collections.randomLatest[1] %}
  {% include "talk-text-card.njk" %}
  </div>
</section>
