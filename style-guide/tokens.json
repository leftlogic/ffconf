{
  "$description": "FFConf design tokens — machine-readable mirror of style-guide/tokens.css. Loosely follows the W3C Design Tokens shape ({ $value, $type }). Values extracted from src/css/*.",
  "color": {
    "brand": {
      "salmon": { "$value": "#ff7063", "$type": "color", "$description": "Primary accent: CTAs, active pills, link hover, rules" },
      "salmonDark": { "$value": "#c04001", "$type": "color", "$description": "Hover/pressed state for salmon surfaces" }
    },
    "ink": {
      "default": { "$value": "#333333", "$type": "color", "$description": "Body and heading text" },
      "muted": { "$value": "#796a6a", "$type": "color", "$description": "Secondary/meta text" },
      "quote": { "$value": "#767676", "$type": "color", "$description": "Blockquote body" },
      "code": { "$value": "#272727", "$type": "color", "$description": "Code foreground" }
    },
    "surface": {
      "white": { "$value": "#ffffff", "$type": "color" },
      "box": { "$value": "#f4f4f4", "$type": "color", "$description": "Default soft panel / pill / input" },
      "boxAlt": { "$value": "#f9f9f9", "$type": "color", "$description": "image-and-text panel" },
      "codeBg": { "$value": "#f3f3f3", "$type": "color", "$description": "pre/code background; table row borders" },
      "markBg": { "$value": "#dddddd", "$type": "color", "$description": "<mark> callout" },
      "overlayDark": { "$value": "#1e1e1e", "$type": "color", "$description": "talk-card image gradient foot" }
    },
    "line": {
      "border": { "$value": "#efefef", "$type": "color", "$description": "Hairlines, card borders (light-grey)" },
      "borderStrong": { "$value": "#cccccc", "$type": "color", "$description": "Code block + playlist tab borders" }
    }
  },
  "shadow": {
    "dropdown": { "$value": "0 20px 20px 0 rgba(51,51,51,0.2)", "$type": "shadow", "$description": "Filter flyout" },
    "menu": { "$value": "0 7px 10px 0 rgba(0,0,0,0.11)", "$type": "shadow", "$description": "Open mobile menu" },
    "card": { "$value": "0 4px 12px 0 rgba(51,51,51,0.08)", "$type": "shadow", "$description": "Feeds filter body" }
  },
  "font": {
    "family": {
      "sans": { "$value": "'BasierSquare', sans-serif", "$type": "fontFamily", "$description": "Brand face; FFC=>ffc ligature" },
      "sansAlt": { "$value": "'Inter', sans-serif", "$type": "fontFamily", "$description": "Opt-in via html.inter / ?font=inter" },
      "mono": { "$value": "'ubuntu mono', menlo, monaco, consolas, courier, 'courier new', 'lucida console', monospace", "$type": "fontFamily" }
    },
    "weight": {
      "regular": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight", "$description": "Headings, links, nav, card titles" },
      "strong": { "$value": 600, "$type": "fontWeight" }
    },
    "size": {
      "2xs": { "$value": "11px", "$type": "dimension" },
      "xs": { "$value": "12px", "$type": "dimension" },
      "s": { "$value": "13px", "$type": "dimension" },
      "sm": { "$value": "14px", "$type": "dimension", "$description": "Body @ mobile" },
      "base": { "$value": "16px", "$type": "dimension" },
      "md": { "$value": "18px", "$type": "dimension", "$description": "Body @ >=700px, nav, buttons" },
      "lg": { "$value": "22px", "$type": "dimension" },
      "xl": { "$value": "24px", "$type": "dimension" },
      "2xl": { "$value": "32px", "$type": "dimension", "$description": "h1, section h2" },
      "3xl": { "$value": "42px", "$type": "dimension" },
      "4xl": { "$value": "56px", "$type": "dimension", "$description": "h1 / hero @ desktop" }
    },
    "lineHeight": {
      "tight": { "$value": 1.2, "$type": "number" },
      "heading": { "$value": 1.27, "$type": "number" },
      "snug": { "$value": 1.33, "$type": "number" },
      "body": { "$value": 1.4, "$type": "number" },
      "base": { "$value": 1.3, "$type": "number", "$description": "Global default on *" }
    }
  },
  "space": {
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "18px", "$type": "dimension" },
    "6": { "$value": "20px", "$type": "dimension" },
    "7": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "28px", "$type": "dimension" },
    "9": { "$value": "32px", "$type": "dimension", "$description": "Dominant page gutter" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "15": { "$value": "60px", "$type": "dimension" },
    "20": { "$value": "80px", "$type": "dimension" },
    "22": { "$value": "88px", "$type": "dimension" },
    "25": { "$value": "100px", "$type": "dimension" }
  },
  "radius": {
    "xs": { "$value": "2px", "$type": "dimension" },
    "sm": { "$value": "3px", "$type": "dimension" },
    "base": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "6px", "$type": "dimension" },
    "lg": { "$value": "8px", "$type": "dimension" },
    "pill": { "$value": "9999px", "$type": "dimension" },
    "circle": { "$value": "50%", "$type": "dimension" }
  },
  "layout": {
    "maxBody": { "$value": "1200px", "$type": "dimension" },
    "maxFeeds": { "$value": "1100px", "$type": "dimension" },
    "maxTalk": { "$value": "920px", "$type": "dimension" },
    "maxProse": { "$value": "70ch", "$type": "dimension" }
  },
  "breakpoint": {
    "feedsNarrow": { "$value": "460px", "$type": "dimension" },
    "main": { "$value": "700px", "$type": "dimension", "$description": "PRIMARY mobile/desktop switch" },
    "feedsWide": { "$value": "720px", "$type": "dimension" },
    "posts": { "$value": "800px", "$type": "dimension" },
    "menuWide": { "$value": "840px", "$type": "dimension" },
    "heroLarge": { "$value": "900px", "$type": "dimension" }
  },
  "motion": {
    "easeOut": { "$value": "ease-out", "$type": "cubicBezier" },
    "easeIn": { "$value": "ease-in", "$type": "cubicBezier" },
    "durFast": { "$value": "60ms", "$type": "duration" },
    "durQuick": { "$value": "80ms", "$type": "duration" },
    "durSnappy": { "$value": "100ms", "$type": "duration" },
    "dur": { "$value": "150ms", "$type": "duration" },
    "durSlow": { "$value": "200ms", "$type": "duration" }
  }
}
